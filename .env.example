AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
DYNAMODB_TABLE_NAME=tradeflow-leads

# Optional: switch the app from DynamoDB to Aurora DSQL.
# Leave DATABASE_BACKEND unset or set to dynamodb for the original hackathon stack.
DATABASE_BACKEND=dynamodb
DSQL_CLUSTER_ENDPOINT=your-cluster-id.dsql.us-east-1.on.aws
DSQL_REGION=us-east-1
DSQL_DATABASE=postgres
DSQL_DB_USER=admin
